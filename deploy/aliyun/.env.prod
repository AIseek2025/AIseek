# AIseek 生产环境配置 - 阿里云部署
# 域名：aiseek.cool
# 生成时间：2026-03-08

# ==================== 数据库配置 ====================
POSTGRES_USER=aiseek
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=aiseek_prod

# ==================== Redis 配置 ====================
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ==================== 安全密钥 ====================
# 生成方法：openssl rand -hex 32
WORKER_SECRET=CHANGE_ME_WORKER_SECRET

# ==================== 域名配置 ====================
WEB_URL=https://aiseek.cool
CALLBACK_URL=https://aiseek.cool/callback

# ==================== 服务并发数 ====================
WEB_CONCURRENCY=4
WORKER_CONCURRENCY=4

# ==================== AI 配置（可选）====================
# 如需启用 AI 功能，填写你的 DeepSeek API Key
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ==================== 对象存储配置（可选）====================
# 阿里云 OSS 或 Cloudflare R2
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
